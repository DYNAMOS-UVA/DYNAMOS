# Docker image name used by dev.sh for the dev container.
DYNAMOS_DEV_IMAGE=dynamos-dev

# Absolute path to this repository ON THE HOST (not inside the container).
# Used by dynamos-configuration.sh to set the Kubernetes hostPath for
# chart deployments. Must be set before running dynamos-configuration.sh
# inside the dev container.
# Example: DYNAMOS_HOST_ROOT=/home/alice/projects/DYNAMOS
DYNAMOS_HOST_ROOT=
